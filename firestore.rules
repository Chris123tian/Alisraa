rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Simplified and more robust admin check for Firestore query optimizer
    function isAdmin() {
      let isPrimaryAdmin = request.auth.token.email == 'alisraainternationaler@gmail.com';
      let hasRoleDoc = exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) && 
                       get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true;
      return isSignedIn() && (isPrimaryAdmin || hasRoleDoc);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow update: if isOwner(userId);
      allow create: if isSignedIn() && request.resource.data.id == request.auth.uid;
      allow list, delete: if isAdmin();
    }

    match /shipments/{shipmentId} {
      // Allow individual document reads for admins or owners
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Explicitly allow admins to list all shipments
      allow list: if isAdmin();
      
      // Allow clients to list only their own shipments (must be filtered by userId in the query)
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Admin only write access
      allow write: if isAdmin();
    }

    match /chat_messages/{messageId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list, create, update, delete: if isAdmin();
    }
  }
}
