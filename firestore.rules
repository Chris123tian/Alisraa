rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Simplified Admin Check
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'alisraainternationaler@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow update: if isOwner(userId);
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /shipments/{shipmentId} {
      // Allow specific document read for admins or owners
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      
      // Allow admins to list all shipments
      allow list: if isAdmin();
      
      // Allow regular users to list ONLY their own shipments (query must filter by userId)
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      // Full write access for admins
      allow write: if isAdmin();
    }

    match /chat_messages/{messageId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list, create, update, delete: if isAdmin();
    }
  }
}
